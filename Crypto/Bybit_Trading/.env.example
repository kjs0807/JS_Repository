# BBKC / Strategy trading - .env template
#
# Copy this file to ``.env`` and fill in the actual values. ``.env`` is
# git-ignored; ``.env.example`` is the only file committed and must NEVER
# contain real credentials.
#
# Endpoint selection: NOT exposed as an env var any more. The Bybit REST
# base_url is derived from ``config.yaml`` ``app.mode`` (demo|live) inside
# ``src.core.mode``. To switch environments, change ``app.mode`` (or pass
# ``--mode demo|live`` on the CLI).
# ----------------------------------------------------------------------

# Bybit demo (testnet/demo). Required when app.mode=demo.
BYBIT_DEMO_API_KEY=<your-demo-api-key>
BYBIT_DEMO_API_SECRET=<your-demo-api-secret>

# Bybit mainnet (REAL MONEY). Required when app.mode=live AND the
# operator passes --i-understand-real-money. The live runner refuses to
# fall back to the legacy un-prefixed pair below.
BYBIT_LIVE_API_KEY=<your-live-api-key>
BYBIT_LIVE_API_SECRET=<your-live-api-secret>

# Telegram alerts (shared across modes). Issue a bot via @BotFather,
# DM it once so it can message you, then look up TELEGRAM_CHAT_ID via
# https://api.telegram.org/bot<token>/getUpdates.
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
TELEGRAM_CHAT_ID=<your-telegram-chat-id>

# ----------------------------------------------------------------------
# Legacy fallback (DEPRECATED). Read only by non-BBKC scripts
# (``scripts/check_account.py``, ``main_live.py``) that have not yet
# been migrated to ``src.core.mode``. The strategy runner accepts these
# ONLY in demo mode and emits a deprecation warning. NEVER use them for
# a live (real-money) run.
# ----------------------------------------------------------------------
# BYBIT_API_KEY=<demo-key-here-if-you-need-legacy-script-compat>
# BYBIT_API_SECRET=<demo-secret-here-if-you-need-legacy-script-compat>
